# Babil Chat Environment Configuration

# OpenAI API Configuration
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key-here
EXPO_PUBLIC_OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Firebase Configuration (Firebase Console'dan kopyala)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-DEMO123
EXPO_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# Prayer Times API
EXPO_PUBLIC_PRAYER_TIMES_API_URL=https://api.aladhan.com/v1/timings
EXPO_PUBLIC_PRAYER_TIMES_METHOD=4

# Quran API Configuration
EXPO_PUBLIC_QURAN_API_URL=https://api.quran.com/api/v4
EXPO_PUBLIC_QURAN_AUDIO_BASE_URL=https://audio.qurancdn.com

# App Configuration
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_BUILD_NUMBER=1
EXPO_PUBLIC_API_BASE_URL=https://api.babilchat.com/v1

# Analytics & Monitoring
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# Premium Features
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
EXPO_PUBLIC_APPLE_MERCHANT_ID=merchant.com.babilchat.app

# Development Settings
EXPO_PUBLIC_DEBUG_MODE=true
EXPO_PUBLIC_LOG_LEVEL=debug

# External APIs
EXPO_PUBLIC_WEATHER_API_KEY=your-weather-api-key
EXPO_PUBLIC_GEOCODING_API_KEY=your-geocoding-api-key

# Database URLs (if using external services)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Social Login
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Push Notifications
EXPO_PUBLIC_FCM_SERVER_KEY=your-fcm-server-key
EXPO_PUBLIC_VAPID_KEY=your-vapid-key 