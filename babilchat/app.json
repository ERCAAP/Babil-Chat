{
  "expo": {
    "name": "Hidayet",
    "slug": "hidayet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hidayet",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hidayet.app",
      "buildNumber": "1",
      "infoPlist": {
        "UISupportsDocumentBrowser": true,
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "UIUserInterfaceStyle": "Dark"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "widgets": [
        {
          "name": "PrayerTimesWidget",
          "displayName": "Prayer Times",
          "description": "Shows daily prayer times",
          "widgetBackgroundColor": "#0f0f23",
          "configurationDisplayName": "Prayer Times Configuration",
          "intentConfiguration": "widgets/PrayerTimesWidget.intentdefinition"
        },
        {
          "name": "DailyVerseWidget",
          "displayName": "Daily Verse",
          "description": "Shows daily Quranic verse",
          "widgetBackgroundColor": "#0f0f23",
          "configurationDisplayName": "Daily Verse Configuration",
          "intentConfiguration": "widgets/DailyVerseWidget.intentdefinition"
        }
      ]
    },
    "android": {
      "package": "com.hidayet.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f0f23"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f0f23"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.ttf",
            "./assets/fonts/Amiri-Bold.ttf",
            "./assets/fonts/Inter-Regular.ttf",
            "./assets/fonts/Inter-Medium.ttf",
            "./assets/fonts/Inter-SemiBold.ttf",
            "./assets/fonts/Inter-Bold.ttf"
          ]
        }
      ],
      [
        "expo-localization",
        {
          "supportsRTL": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
